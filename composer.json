{
    "name": "ailuracode/bladcn",
    "description": "A styled Blade component library built on top of BlaseUI",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "AiluraCode",
            "email": "info@ailuracode.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "pestphp/pest": "^3.8",
        "orchestra/testbench": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "AiluraCode\\Bladcn\\": "src/",
            "AiluraCode\\Bladcn\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AiluraCode\\Bladcn\\BladcnServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
