{
  "name": "ailuracode/bladcn",
  "description": "A styled Blade component library built on top of BlaseUI",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "AiluraCode",
      "email": "info@ailuracode.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "laravel/framework": "^13.0",
    "mallardduck/blade-lucide-icons": "^1.26"
  },
  "require-dev": {
    "driftingly/rector-laravel": "^2.3.0",
    "laravel/pint": "^1.29",
    "pestphp/pest": "^3.8",
    "orchestra/testbench": "^11.0",
    "rector/rector": "^2.4.2"
  },
  "scripts": {
    "setup": [
      "composer install",
      "npm install"
    ],
    "lint:check": [
      "pint --parallel --test"
    ],
    "lint": [
      "rector",
      "pint --parallel"
    ]
  },
  "autoload": {
    "files": [
      "src/helpers.php"
    ],
    "psr-4": {
      "AiluraCode\\Bladcn\\": "src/",
      "AiluraCode\\Bladcn\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AiluraCode\\Bladcn\\BladcnServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
